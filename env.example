# VARIABLES DE ENTORNO — Chatbot Quaxar IA


# OPENAI

# Obtener la API Key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar.
MODEL_NAME=gpt-3.5-turbo

# Temperatura del modelo (0.0 = deterministico, 1.0 = creativo)
# Para un chatbot de atencion al cliente se recomienda 0.0
TEMPERATURE=0.0


# SEGURIDAD

# Clave secreta para autenticar el plugin de WordPress con la API.
# El plugin debe enviar esta clave en el header: X-API-Key: <valor>
# Generar una clave segura ejecutando en la terminal:
#   python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=reemplaza-esto-con-una-clave-generada


# CORS

# Lista de dominios de los sitios WordPress en formato JSON.
# No usar ["*"] en produccion. Solo poner los dominios reales.
#
# Ejemplos:
#   Un solo sitio:    CORS_ORIGINS=["https://tu-sitio.com"]
#   Varios sitios:    CORS_ORIGINS=["https://sitio1.com","https://sitio2.com"]
#   Desarrollo local: CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ORIGINS=["https://tu-sitio-wordpress.com"]


# CHROMADB

# Directorio donde se persisten los datos de ChromaDB
CHROMA_DB_DIR=./data/chroma

# Nombre de la coleccion. Debe ser el mismo en API, dashboard e ingest.py
COLLECTION_NAME=documentos_chatbot


# RAG

# Numero maximo de chunks a recuperar por consulta
TOP_K_RESULTS=5

# Tamano de cada chunk al procesar PDFs
CHUNK_SIZE=1000

# Superposicion entre chunks para no perder contexto entre fragmentos
CHUNK_OVERLAP=200


# LOGGING

# Nivel de logs: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Usar INFO en produccion. Usar DEBUG en desarrollo.
LOG_LEVEL=INFO
